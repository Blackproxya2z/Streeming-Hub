generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String?
  description String?
  isAdult     Boolean   @default(false)
  order       Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  description  String
  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image        String?
  basePriceBDT String    @default("Inbox Price")
  priceOptions String    @default("[]") // JSON array: [{label, priceBDT, priceRMB}]
  duration     String?
  accountType  String?
  region       String?
  warranty     String?
  deliveryTime String    @default("5-20 minutes")
  stockStatus  String    @default("Available") // Available, Limited Stock, Out of Stock
  isFeatured   Boolean   @default(false)
  isBestSeller Boolean   @default(false)
  isNewArrival Boolean   @default(false)
  features     String    @default("[]") // JSON array of feature strings
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  text      String
  product   String?
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Order {
  id               String   @id @default(cuid())
  productName      String
  customerName     String
  whatsappNumber   String
  email            String?
  planDuration     String?
  accountType      String?
  quantity         Int      @default(1)
  notes            String?
  paymentMethod    String?
  transactionLast3 String?
  status           String   @default("Pending")
  createdAt        DateTime @default(now())
}

model Banner {
  id        String   @id @default(cuid())
  text      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
